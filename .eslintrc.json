{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "prefer-const": "warn",
    "no-var": "warn",
    "no-console": "warn",
    "eqeqeq": "warn",
    "curly": "warn",
    "semi": ["warn", "always"],
    "no-trailing-spaces": "warn",
    "eol-last": "warn"
  },
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "ignorePatterns": [
    "node_modules/",
    ".next/",
    "out/",
    "build/",
    "dist/",
    "*.config.js",
    "*.config.ts"
  ]
}
